FLASK_ENV=development
DATABASE_URI=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/tredicy_db
SECRET_KEY=change-this-secret
UPLOADS_S3_BUCKET=
UPLOADS_S3_REGION=
UPLOADS_PUBLIC_BASE_URL=
UPLOADS_S3_PREFIX=uploads
UPLOADS_S3_ACL=public-read
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
SQUARE_DEPOSIT_AMOUNT_CENTS=10000
SQUARE_DEPOSIT_CURRENCY=USD
SQUARE_FAKE_PAYMENTS=true
MAILGUN_DOMAIN=mg.example.com
MAILGUN_API_KEY=key-your-mailgun-api-key
MAILGUN_FROM=Black Ink Tattoo <noreply@mg.example.com>
MAILGUN_FROM_EMAIL=Black Ink Tattoo <noreply@mg.example.com>
CLIENT_BASE_URL=http://localhost:5173
